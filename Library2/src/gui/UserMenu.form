        </constraints>
        <properties>
          <text value="Borrowed books"/>
        </properties>
      </component>
      <component id="db998" class="javax.swing.JButton" binding="returnBookButton">
        <constraints>
          <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <text value="Return book"/>
        </properties>
      </component>
      <component id="62031" class="javax.swing.JButton" binding="borrowBookButton">
